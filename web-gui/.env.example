WEB_GUI_HOST=0.0.0.0
WEB_GUI_PORT=8002
API_BASE_URL=http://university-agent:8000
API_KEY=change-me-to-random-string
LOG_LEVEL=INFO
REQUEST_TIMEOUT=120.0
ACTIVE_USER_WINDOW_SECONDS=300

# Google OAuth 2.0 (создать клиента "Web application" в Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8002/auth/google/callback
POST_LOGIN_REDIRECT=/gui/

# JWT-сессия (openssl rand -hex 32)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_TTL_SECONDS=604800
COOKIE_SECURE=false
COOKIE_NAME=unibot_session

# true = вход открыт без авторизации (только для разработки)
AUTH_DISABLED=false
