# ════════════════════════════════════════════
# ОБЯЗАТЕЛЬНО ЗАПОЛНИТЬ (4 строки)
# ════════════════════════════════════════════
server_ip: 123.45.67.89                                   # IP арендованного сервера
repo_url: https://github.com/username/unibot.git          # реальный адрес репозитория (для приватного — с токеном)
routerai_api_key: "sk-..."                                # ключ к LLM, без него агент не отвечает

# ════════════════════════════════════════════
# Доступ по SSH
# ════════════════════════════════════════════
deploy_user: deploy
ssh_key_path: ~/.ssh/id_ed25519
app_dir: /opt/unibot
repo_branch: main

# ════════════════════════════════════════════
# Пароли БД/хранилищ.
# ВНИМАНИЕ: docker-compose.yml жёстко прописывает значения "change-me-*".
# Чтобы приложение и контейнеры совпали, эти пароли НЕ меняем для разовой демонстрации.
# (Порты баз наружу закрыты — это безопасно для показа.)
# ════════════════════════════════════════════
postgres_user: unibot
postgres_password: "change-me-postgres-password"
postgres_db: university
minio_root_user: minioadmin
minio_root_password: "change-me-minio-password"
indexer_admin_password: "change-me-indexer-password"     # вход в Indexer UI (загрузка базы знаний)

# ════════════════════════════════════════════
# Веб-поиск (необязательно, можно оставить пустым)
# ════════════════════════════════════════════
serpapi_api_key: ""
tavily_api_key: ""

# ════════════════════════════════════════════
# Какие сервисы поднимать. Пусто/не задано = весь стек (с мониторингом).
# Чтобы убрать мониторинг и сэкономить память — перечисли нужные сервисы:
# compose_services: "postgres redis qdrant minio university-agent celery-worker indexer web-gui log-viewer nginx"
# ════════════════════════════════════════════

# ════════════════════════════════════════════
# Открытые порты фаервола
#   22 — SSH, 80 — сайт (QR ведёт сюда), 8001 — Indexer UI (загрузка базы знаний)
#   3000 — Grafana (графики метрик для комиссии)
#   443 — раскомментируй, если перейдёшь на HTTPS (сертификат самоподписанный)
# ════════════════════════════════════════════
open_ports:
  - "22/tcp"
  - "80/tcp"
  - "8001/tcp"
  - "3000/tcp"
  # - "443/tcp"
